# Configurações do Supabase (Obrigatório)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key (NUNCA NO FRONTEND)

# Configurações de Sessão e Segurança
SESSION_SECRET=a-very-long-and-secure-random-string
ENCRYPTION_KEY=base64-url-safe-key (Para regra Lion Lab 04)

# Configurações de Ambiente
APP_ENV=development # development, staging, production

# APIs de Terceiros (Opcional)
# OPENAI_API_KEY=sk-xxxx
# ANTHROPIC_API_KEY=sk-ant-xxxx
