{
    "mcpServers": {
        "context7": {
        "command": "cmd",
        "args": [
            "/c",
            "npx",
            "-y",
            "@upstash/context7-mcp",
                "--api-key",
                "YOUR_API_KEY"
            ]
        },
        "shadcn": {
        "command": "cmd",
        "args": [
            "/c",
            "npx",
            "shadcn@latest",
                "mcp"
            ]
        }
        //other mcp servers
    }
}

// setup mcp server in  ~/.gemini\antigravity\mcp_config.json

